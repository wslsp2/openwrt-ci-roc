# 平台架构
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 只编译亚瑟 RE-SS-01（屏蔽雅典娜、07 所有其他机型）
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=n

# 亚瑟 512M 内存
CONFIG_ATH11K_MEM_PROFILE_512M=y

# NSS 硬件加速（必须开，千兆满速）
CONFIG_NSS_FIRMWARE_VERSION_12_5=y

# 插件（精简保留：gecoosac 加速）
CONFIG_PACKAGE_luci-app-gecoosac=y

# ================== 彻底关闭 WiFi ==================
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpa-supplicant-basic=n
CONFIG_PACKAGE_iw=n
CONFIG_KERNEL_IPQ6018_WIFI=n

# ================== 关闭 Docker（完全不编译） ==================
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_dockerman=n

# ================== 关闭 LED 插件（精简） ==================
CONFIG_PACKAGE_luci-app-athena-led=y
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=y
